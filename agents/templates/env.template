# ──────────────────────────────────────────────
# Project environment variables
# ──────────────────────────────────────────────
# Copy to .env and fill in values.
# Loaded automatically by direnv (see .envrc)
# NEVER commit .env — only .env.template

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# ── dbt ──
# DBT_PROFILES_DIR=.    # use local profiles.yml instead of ~/.dbt/
# DBT_TARGET=dev

# ── Snowflake (if applicable) ──
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_ROLE=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=

# ── BigQuery (if applicable) ──
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GCP_PROJECT=

# ── SQLPrism ──
# SQLPRISM_CONFIG=sqlprism.yml
