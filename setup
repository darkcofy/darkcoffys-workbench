#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────
# darkcoffys-workbench setup
# ──────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODE="full"

print_usage() {
    cat <<'EOF'

  darkcoffys-workbench setup
  ══════════════════════════

  Usage:
    ./setup                  Full setup (WezTerm + VS Code + shell tools + neovim)
    ./setup --low-power      Minimal setup (tmux + neovim + shell tools)
    ./setup --lp             Same as --low-power
    ./setup --uninstall      Remove all symlinks and configs

  Modes:
    full        WezTerm, VS Code extensions, fonts, Docker, neovim, shell tools
    low-power   tmux, neovim, shell tools (no GUI needed)

  Both modes include:
    Python toolchain (uv, ruff, pre-commit), git config, starship prompt,
    zoxide, fzf, direnv, aliases, SSH key setup, CLI tools (onboard, scaffold)

EOF
}

for arg in "$@"; do
    case "$arg" in
        --low-power|--lp|-lp) MODE="lowpower" ;;
        --uninstall)          MODE="uninstall" ;;
        --help|-h)            print_usage; exit 0 ;;
        *)                    echo "Unknown flag: $arg"; print_usage; exit 1 ;;
    esac
done

cd "$SCRIPT_DIR"

case "$MODE" in
    full)
        echo ""
        echo "  ☕ Full workbench setup"
        echo ""
        make deps-full
        make fonts
        make python-tools
        make shell-tools
        make shell-rc
        make git-config
        make nvim
        make wezterm
        make vscode
        make onboard-link
        make docker
        echo ""
        echo "  ──────────────────────────────────────"
        echo "  ✓ Full setup complete."
        echo ""
        echo "  Quick start:"
        echo "    1. Open a new terminal (or: source ~/.zshrc)"
        echo "    2. Run: ssh-setup           ← generate SSH key for GitHub"
        echo "    3. Run: onboard <repo-url>  ← clone + setup any project"
        echo ""
        ;;
    lowpower)
        echo ""
        echo "  ⚡ Low-power workbench setup"
        echo ""
        make deps-lowpower
        make python-tools
        make shell-tools
        make shell-rc
        make git-config
        make nvim
        make tmux
        make onboard-link
        echo ""
        echo "  ──────────────────────────────────────"
        echo "  ✓ Low-power setup complete."
        echo ""
        echo "  Quick start:"
        echo "    1. Open a new terminal (or: source ~/.bashrc)"
        echo "    2. Run: ssh-setup           ← generate SSH key for GitHub"
        echo "    3. Run: tmux → nvim         ← start editing"
        echo "    4. Run: onboard <repo-url>  ← clone + setup any project"
        echo ""
        ;;
    uninstall)
        make uninstall
        ;;
esac
