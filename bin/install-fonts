#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────
# darkcoffys-workbench :: font installer
# ──────────────────────────────────────────────
# Installs JetBrains Mono Nerd Font (used by
# WezTerm, neovim, terminal configs)
# ──────────────────────────────────────────────

# Resolve symlinks portably (works on both Linux and macOS)
resolve_path() {
    local target="$1"
    while [ -L "$target" ]; do
        local dir="$(cd "$(dirname "$target")" && pwd)"
        target="$(readlink "$target")"
        [[ "$target" != /* ]] && target="$dir/$target"
    done
    echo "$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
}
SCRIPT_PATH="$(resolve_path "${BASH_SOURCE[0]}")"
WORKBENCH_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

source "$WORKBENCH_DIR/lib/common.sh"

UNAME="$(uname -s)"
FONT_NAME="JetBrainsMono"
NERD_FONT_VERSION="v3.3.0"

echo ""
echo -e "  ${CYAN}darkcoffys install-fonts${RESET}"
echo "  ═══════════════════════"
echo ""

# ── Check if already installed ──
FONT_INSTALLED=false

if [[ "$UNAME" == "Darwin" ]]; then
    FONT_DIR="$HOME/Library/Fonts"
    fc-list 2>/dev/null | grep -qi "JetBrains" && FONT_INSTALLED=true
else
    FONT_DIR="$HOME/.local/share/fonts"
    fc-list 2>/dev/null | grep -qi "JetBrains" && FONT_INSTALLED=true
fi

if $FONT_INSTALLED; then
    info "JetBrains Mono already installed"
    echo -e "  ${DIM}$(fc-list | grep -i 'JetBrains' | head -3)${RESET}"
    echo ""
    exit 0
fi

# ── Download and install ──
step "Downloading JetBrains Mono Nerd Font ${NERD_FONT_VERSION}..."

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

curl -fsSL -o "$TMPDIR/$FONT_NAME.zip" \
    "https://github.com/ryanoasis/nerd-fonts/releases/download/${NERD_FONT_VERSION}/${FONT_NAME}.zip"

info "Downloaded"

step "Installing to $FONT_DIR..."
mkdir -p "$FONT_DIR"
unzip -oq "$TMPDIR/$FONT_NAME.zip" -d "$FONT_DIR/" -x "*.txt" -x "*.md" -x "LICENSE*"

# ── Rebuild font cache ──
if command -v fc-cache &>/dev/null; then
    step "Rebuilding font cache..."
    fc-cache -f "$FONT_DIR"
fi

info "JetBrains Mono Nerd Font installed"
echo ""
echo -e "  ${DIM}Restart your terminal/WezTerm to pick up the new font.${RESET}"
echo ""
